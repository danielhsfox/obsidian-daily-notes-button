{
	"name": "obsidian-daily-notes-button",
	"version": "1.0.0",
	"description": "Adds a customizable button to create/open your daily note with automatic template processing, conditional tasks, and pending tasks migration",
	"main": "main.js",
	"type": "module",
	"scripts": {
		"dev": "node esbuild.config.mjs",
		"build": "tsc -noEmit -skipLibCheck && node esbuild.config.mjs production",
		"version": "node version-bump.mjs && git add manifest.json versions.json",
		"lint": "eslint ."
	},
	"keywords": [
		"obsidian",
		"obsidian-plugin",
		"daily-notes",
		"templater",
		"tasks",
		"productivity",
		"note-taking"
	],
	"author": "danielhsfox",
	"license": "MIT",
	"devDependencies": {
		"@types/node": "^16.11.6",
		"esbuild": "0.25.5",
		"eslint-plugin-obsidianmd": "0.1.9",
		"globals": "14.0.0",
		"tslib": "2.4.0",
		"typescript": "^5.8.3",
		"typescript-eslint": "8.35.1",
		"@eslint/js": "9.30.1",
		"jiti": "2.6.1"
	},
	"dependencies": {
		"obsidian": "latest"
	},
	"repository": {
		"type": "git",
		"url": "https://github.com/yourusername/obsidian-daily-notes-button"
	},
	"bugs": {
		"url": "https://github.com/yourusername/obsidian-daily-notes-button/issues"
	},
	"homepage": "https://github.com/yourusername/obsidian-daily-notes-button"
}